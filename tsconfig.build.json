{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "node_modules",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.test-d.ts"
  ]
}
